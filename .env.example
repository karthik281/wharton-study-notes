# ============================================================
# Wharton Study Notes Agent - Configuration
# ============================================================

# Anthropic (required)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Panopto server (required)
# Your institution's Panopto hostname, no https://
PANOPTO_SERVER=upenn.hosted.panopto.com

# Panopto auth - Option A: Browser cookie (recommended, works with SSO)
# 1. Log into your Panopto in Chrome/Edge
# 2. Press F12 -> Application tab -> Cookies -> your Panopto URL
# 3. Copy the Value of .ASPXAUTH or PanoptoSiteAuth
# 4. Paste below (include the cookie name)
PANOPTO_COOKIE=.ASPXAUTH=<paste-your-cookie-value-here>

# Panopto auth - Option B: OAuth2 (if your institution enables it)
# PANOPTO_CLIENT_ID=
# PANOPTO_CLIENT_SECRET=
# PANOPTO_USERNAME=
# PANOPTO_PASSWORD=

# How many recent sessions to process per run (default: 20)
# Increase to 100+ for an initial backfill of older sessions
MAX_SESSIONS_PER_RUN=20

# Canvas API (optional - most students cannot access this)
# CANVAS_URL=https://canvas.upenn.edu
# CANVAS_API_TOKEN=
